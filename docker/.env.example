# Project directory name inside the container.
# Auto-detected from the repo directory name by docker_env.sh.
# Only set this if you need to override the default.
# PROJECT_DIR=MyProject

# Local paths to your framework clones (used by docker-compose for volume mounts)
# Defaults to sibling directories next to this repo (../../EventOS, ../../UnitTest)
# EVENTOS_PATH=/path/to/your/EventOS
# UNITTEST_PATH=/path/to/your/UnitTest

# Optional: path to a cross-compiler toolchain install
# TOOLCHAIN_PATH=/path/to/your/toolchain
